# Grep Check Registry — llm pack fragment
#
# LLM-specific checks (cost guardrails, prompt safety, eval
# correctness). The Phase 3 installer concatenates this fragment
# with core/companion/checks.yml.fragment (and any other selected
# pack fragments) into the project-side .claude/checks.yml.
# Path globs use placeholder vocabulary that the installer
# substitutes per project from convention_map.md.
#
# Format docs: WORKFLOW.md §6.5

checks:
  # ── Semgrep / AST diagnostics ──────────────────────────────────
  # No `pattern` field — populated by `_run_semgrep()` in
  # scripts/run_checks_impl.py from the pack's semgrep/*.yaml rules.
  # Starts blocking: false — CI does not install semgrep yet.

  - id: semgrep-llm-cost-abuse
    name: "LLM Cost Abuse — Missing max_output_tokens (semgrep)"
    category: security
    severity: high
    paths: ["<api module>/", "<scripts dir>/"]
    description: "GenerateContentConfig(...) constructor without max_output_tokens — unbounded LLM output cost"
    convention: "LLM output bounds"
    used_by: [security-audit]
    blocking: false
