#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────
# pre-merge-commit — Runs before a merge completes on the
# protected branch (default: main). If tests or builds fail,
# the merge is BLOCKED.
#
# Bypass (not recommended): git merge --no-verify
#
# This is a skeleton. Each project fills in its own backend-test
# and frontend-build commands based on the conventions in
# CLAUDE.md and convention_map.md.
# See core/companion/git-hooks/examples/pre-merge-commit-python.example
# for a worked example (Python web service + Next.js frontend).
#
# SECURITY: this hook intentionally does NOT source .env (or any
# other secret file). Sourcing .env (a) exports every variable
# into the test process whether the tests need it or not, and
# (b) executes shell metacharacters in .env (e.g., $(curl …) or
# backticks) on every merge commit. If the tests legitimately
# need a secret, plumb it through pytest fixtures / conftest.py
# (or the equivalent for your test framework) so the surface is
# scoped to the test that asked for it.
# ──────────────────────────────────────────────────────────────
set -euo pipefail

# Adjust to your project's protected branch name if not "main".
PROTECTED_BRANCH="main"

TARGET_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [[ "$TARGET_BRANCH" != "$PROTECTED_BRANCH" ]]; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
CHANGED=$(git diff --cached --name-only 2>/dev/null || git diff HEAD~1 --name-only 2>/dev/null || echo "")
if [[ -z "$CHANGED" ]]; then
  exit 0
fi

echo ""
echo "🔒 pre-merge-commit: Running checks before merging to ${PROTECTED_BRANCH}..."
echo ""

FAILED=false

