{
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(git merge --ff-only:*)",
      "Bash(git rebase:*)",
      "Bash(git rebase --abort)",
      "Bash(git branch -d:*)",
      "Bash(git worktree list)",
      "Bash(git worktree add:*)",
      "Bash(git worktree remove:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git tag:*)",
      "Bash(git push origin:*)",
      "Bash(git push -u origin:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git add tasks/index.yml)",
      "Bash(git add review_tasks.md)",
      "Bash(git commit -m claim:*)",
      "Bash(git commit -m rollback:*)",
      "Bash(git commit -m docs:*)",
      "Bash(bash scripts/claim_task.sh:*)",
      "Bash(bash scripts/batch_work.sh:*)",
      "Bash(bash scripts/close_batch.sh:*)",
      "Bash(bash scripts/run_checks.sh)",
      "Bash(bash scripts/run_checks.sh:*)",
      "Bash(bash scripts/install_hooks.sh)",
      "Bash(bash scripts/sysop-update.sh)",
      "Bash(bash scripts/sysop-update.sh:*)",
      "Bash(python scripts/archive_review_tasks.py:*)",
      "Bash(python3 scripts/archive_review_tasks.py:*)",
      "Bash(python3 -c:*)",
      "Bash(python3 -:*)",
      "Bash(python3 scripts/validate_tasks.py)",
      "Bash(python3 scripts/validate_tasks.py:*)",
      "Bash(.venv/bin/python3 scripts/validate_tasks.py)",
      "Bash(.venv/bin/python3 scripts/validate_tasks.py:*)",
      "Bash(.venv/bin/python3 scripts/archive_review_tasks.py:*)",
      "Bash(python3 scripts/sitrep_survey.py)",
      "Bash(python3 scripts/sitrep_survey.py:*)",
      "Bash(python3 scripts/next_task.py)",
      "Bash(python3 scripts/next_task.py:*)",
      "Bash(.venv/bin/python3 scripts/next_task.py)",
      "Bash(.venv/bin/python3 scripts/next_task.py:*)",
      "Bash(python3 scripts/scope_overlap.py)",
      "Bash(python3 scripts/scope_overlap.py:*)",
      "Bash(.venv/bin/python3 scripts/scope_overlap.py)",
      "Bash(.venv/bin/python3 scripts/scope_overlap.py:*)",
      "Bash(python3 scripts/pr_dependabot.py:*)",
      "Bash(.venv/bin/python3 scripts/pr_dependabot.py:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue create:*)",
      "Bash(gh release create:*)",
      "Bash(gh api graphql:*)"
    ]
  },
  "hooks": {
    "PermissionDenied": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/scripts/permission_denied_hook.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PROJECT_DIR/scripts/parse_subagent_envelope.py"
          }
        ]
      }
    ]
  }
}
